# ── GitHub configuration ──────────────────────────────────────────────────────
# Your GitHub username (repo owner)
NEXT_PUBLIC_GITHUB_OWNER=brittytino

# The repository name
NEXT_PUBLIC_GITHUB_REPO=placement-readiness

# Optional: GitHub personal access token to avoid rate limits on the Contents API.
# Without this, unauthenticated requests are limited to 60/hour per IP.
# Generate one at: https://github.com/settings/tokens (read:public_repo scope is enough)
GITHUB_TOKEN=

# ── Vercel (for local dev only — set VERCEL_DEPLOY_HOOK as a GitHub Actions Secret) ──
# VERCEL_DEPLOY_HOOK=https://api.vercel.com/v1/integrations/deploy/...
